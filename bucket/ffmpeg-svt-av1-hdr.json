{
    "version": "2026.07.08",
    "description": "FFmpeg builds with SVT-AV1 and HDR support (master branch, latest release)",
    "homepage": "https://github.com/QuickFatHedgehog/FFmpeg-Builds-SVT-AV1-HDR",
    "license": "GPL-3.0-or-later",
    "notes": [
        "This is the 'master-latest' build, updated daily.",
        "Executables are aliased with '-svt-av1-hdr' suffix to avoid conflicts."
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/QuickFatHedgehog/FFmpeg-Builds-SVT-AV1-HDR/releases/download/latest/ffmpeg-master-latest-win64-gpl.zip",
            "hash": "b8148d7d10792a6b1cadea8244f8d5f676831005f8bfa46c630522b73c975f3a",
            "extract_dir": "ffmpeg-master-latest-win64-gpl"
        },
        "arm64": {
            "url": "https://github.com/QuickFatHedgehog/FFmpeg-Builds-SVT-AV1-HDR/releases/download/latest/ffmpeg-master-latest-winarm64-gpl.zip",
            "hash": "8e465af1812049016a59b72e36f0f83b599fee7a57ff388ea38936d2e0f15960",
            "extract_dir": "ffmpeg-master-latest-winarm64-gpl"
        }
    },
    "post_install": [
        "# Remove conflicting shims created by Scoop (if any)",
        "Remove-Item \"$scoopdir\\shims\\ffmpeg.ps1\", \"$scoopdir\\shims\\ffplay.ps1\", \"$scoopdir\\shims\\ffprobe.ps1\" -ErrorAction SilentlyContinue"
    ],
    "bin": [
        [
            "bin\\ffmpeg.exe",
            "ffmpeg-svt-av1-hdr"
        ],
        [
            "bin\\ffplay.exe",
            "ffplay-svt-av1-hdr"
        ],
        [
            "bin\\ffprobe.exe",
            "ffprobe-svt-av1-hdr"
        ]
    ],
    "checkver": {
        "script": [
            "$rel = Invoke-RestMethod -Uri 'https://api.github.com/repos/QuickFatHedgehog/FFmpeg-Builds-SVT-AV1-HDR/releases/latest'",
            "$assets = $rel.assets",
            "$x64 = $assets | Where-Object { $_.name -eq 'ffmpeg-master-latest-win64-gpl.zip' } | Select-Object -First 1",
            "$arm = $assets | Where-Object { $_.name -eq 'ffmpeg-master-latest-winarm64-gpl.zip' } | Select-Object -First 1",
            "$ver = $rel.published_at.ToString('yyyy.MM.dd')",
            "$x64hash = if ($x64) { ($x64.digest -split ':')[-1] } else { '0' * 64 }",
            "$armhash = if ($arm) { ($arm.digest -split ':')[-1] } else { '0' * 64 }",
            "Write-Output \"$ver $x64hash $armhash\""
        ],
        "regex": "(?<version>\\d{4}\\.\\d{2}\\.\\d{2})\\s+(?<x64hash>[a-fA-F0-9]{64})\\s+(?<armhash>[a-fA-F0-9]{64})"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/QuickFatHedgehog/FFmpeg-Builds-SVT-AV1-HDR/releases/download/latest/ffmpeg-master-latest-win64-gpl.zip",
                "hash": "$matchX64hash",
                "extract_dir": "ffmpeg-master-latest-win64-gpl"
            },
            "arm64": {
                "url": "https://github.com/QuickFatHedgehog/FFmpeg-Builds-SVT-AV1-HDR/releases/download/latest/ffmpeg-master-latest-winarm64-gpl.zip",
                "hash": "$matchArmhash",
                "extract_dir": "ffmpeg-master-latest-winarm64-gpl"
            }
        }
    }
}
