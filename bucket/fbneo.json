    ],
    "checkver": {
        "script": [
            "$rel = Invoke-RestMethod -Uri 'https://api.github.com/repos/finalburnneo/FBNeo/releases/latest'",
            "$date = $rel.published_at.ToString('yyyyMMdd')",
            "$commit = $rel.target_commitish.Substring(0,7)",
            "$version = \"$date-$commit\"",
            "$x64 = $rel.assets | Where-Object { $_.name -eq 'windows-x86_64.zip' } | Select-Object -First 1",
            "$x32 = $rel.assets | Where-Object { $_.name -eq 'windows-x86_32.zip' } | Select-Object -First 1",
            "$x64hash = if ($x64) { ($x64.digest -split ':')[-1] } else { '' }",
            "$x32hash = if ($x32) { ($x32.digest -split ':')[-1] } else { '' }",
            "Write-Output \"$version $x64hash $x32hash\""
        ],
        "regex": "(?<version>\\d{8}-[a-fA-F0-9]{7})\\s+(?<x64hash>[a-fA-F0-9]{64})\\s+(?<x32hash>[a-fA-F0-9]{64})"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/finalburnneo/FBNeo/releases/download/latest/windows-x86_64.zip",
                "hash": "$matchX64hash"
            },
            "32bit": {
                "url": "https://github.com/finalburnneo/FBNeo/releases/download/latest/windows-x86_32.zip",
                "hash": "$matchX32hash"
            }
        }
    }
}
